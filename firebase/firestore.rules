rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Admin check: user is admin if admins/admin_user has their UID ──
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/admin_user)
        && get(/databases/$(database)/documents/admins/admin_user).data.uid == request.auth.uid;
    }
    
    // ── Players ──────────────────────────────────────
    match /players/{playerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // ── Matches ──────────────────────────────────────
    match /matches/{matchId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // ── Events ───────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // ── Rankings ─────────────────────────────────────
    match /rankings/{rankingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // ── Admin docs (only admin can read/write) ───────
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
